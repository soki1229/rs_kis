# ============================================================
# KIS OpenAPI — 환경 변수 템플릿
# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요.
# .env 는 git에 커밋되지 않습니다.
# ============================================================

# ------------------------------------------------------------
# [실전투자] KIS 실전 계좌
# https://apiportal.koreainvestment.com → 앱 등록 → 실전
# ------------------------------------------------------------
APP_KEY=your_real_app_key_here
APP_SECRET=your_real_app_secret_here

# 계좌번호: 앞 8자리-뒤 2자리  (예: 50123456-01)
ACCOUNT_NUM=XXXXXXXX-XX

# REST API 기본 URL (변경 불필요)
REST_URL=https://openapi.koreainvestment.com:9443

# WebSocket URL (변경 불필요)
WS_URL=wss://ops.koreainvestment.com:21000

# ------------------------------------------------------------
# [모의투자] VTS (Virtual Trading System)
# https://apiportal.koreainvestment.com → 앱 등록 → 모의
# ------------------------------------------------------------
VTS_APP_KEY=your_vts_app_key_here
VTS_APP_SECRET=your_vts_app_secret_here

# 모의투자 계좌번호
VTS_ACCOUNT_NUM=XXXXXXXX-XX

# 모의투자 REST URL (변경 불필요)
VTS_REST_URL=https://openapivts.koreainvestment.com:29443

# 모의투자 WebSocket URL (변경 불필요)
VTS_WS_URL=wss://ops.koreainvestment.com:31000

# ------------------------------------------------------------
# 토큰 캐시 경로 (기본값: ~/.config/kis_api/token.json)
# 재시작마다 토큰 재발급을 피하기 위해 로컬에 저장
# ------------------------------------------------------------
TOKEN_CACHE_PATH=~/.config/kis_api/token.json
VTS_TOKEN_CACHE_PATH=~/.config/kis_api/vts_token.json

# ------------------------------------------------------------
# 통합 테스트 활성화
# "1" 로 설정 시 실제 API 호출 테스트 실행
# cargo test --features integration 실행 시 참조
# ------------------------------------------------------------
KIS_INTEGRATION_TEST=0
