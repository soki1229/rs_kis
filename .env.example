# ============================================================
# KIS OpenAPI — 환경 변수 템플릿
# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요.
# .env 는 git에 커밋되지 않습니다.
# ============================================================

# ------------------------------------------------------------
# [실전투자] KIS 실전 계좌
# https://apiportal.koreainvestment.com → 앱 등록 → 실전
# ------------------------------------------------------------
KIS_APP_KEY=your_real_app_key_here
KIS_APP_SECRET=your_real_app_secret_here

# 계좌번호 앞 8자리 / 뒤 2자리 (예: 50123456 / 01)
KIS_ACCOUNT_NO=XXXXXXXX
KIS_ACCOUNT_CD=01

# ------------------------------------------------------------
# [모의투자] VTS (Virtual Trading System)
# https://apiportal.koreainvestment.com → 앱 등록 → 모의
# KIS_VTS_* 가 없으면 KIS_APP_KEY/KIS_ACCOUNT_NO 로 폴백됨
# ------------------------------------------------------------
KIS_VTS_APP_KEY=your_vts_app_key_here
KIS_VTS_APP_SECRET=your_vts_app_secret_here

KIS_VTS_ACCOUNT_NO=XXXXXXXX
KIS_VTS_ACCOUNT_CD=01

# ------------------------------------------------------------
# 통합 테스트 활성화
# "1" 로 설정 시 실제 API 호출 테스트 실행
# KIS_INTEGRATION_TEST=1 cargo test -p kis_api
# ------------------------------------------------------------
KIS_INTEGRATION_TEST=0
